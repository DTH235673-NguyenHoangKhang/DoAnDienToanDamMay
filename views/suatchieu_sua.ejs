<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/CSS/DoAn.css" />
    <title>
        <%= title%> - Quản lý rạp phim
    </title>
</head>

<body>
    <div id="khungtrang">
        <div id="header">
            <img src="/images/banner.jpg" />
        </div>

        <%- include('navbar') %>

            <div class="card mt-3">
                <div class="card-header">
                    <%= title%>
                </div>
                <div class="card-body">
                    <form action="/suatchieu/sua/<%= suatchieu._id %>" method="post" class="needs-validation"
                        novalidate>
                        <div class="mb-3">
                            <label for="Phim" class="form-label">Tên phim</label>
                            <select class="form-select" id="Phim" name="Phim" required>
                                <option value="">-- Chọn phim --</option>
                                <% phims.forEach(function(item) { %>
                                    <option value="<%= item._id %>" <%=suatchieu.Phim.toString()===item._id.toString()
                                        ? 'selected' : '' %>>
                                        <%= item.TenPhim %>
                                    </option>
                                    <% }); %>
                            </select>

                            <select class="form-select" id="PhongChieu" name="PhongChieu" required>
                                <option value="">-- Chọn phòng chiếu --</option>
                                <% phongchieus.forEach(function(item) { %>
                                    <option value="<%= item._id %>"
                                        <%=suatchieu.PhongChieu.toString()===item._id.toString() ? 'selected' : '' %>>
                                        <%= item.TenPhongChieu %>
                                    </option>
                                    <% }); %>
                            </select>

                            <div class="mb-3">
                                <label for="NgayChieu" class="form-label">Ngày chiếu</label>
                                <% let dateVal="" ;
                                    if(suatchieu.NgayChieu) { dateVal=new
                                    Date(suatchieu.NgayChieu).toLocaleDateString('sv-SE'); } %>
                                    <input type="date" class="form-control" id="NgayChieu" name="NgayChieu"
                                        value="<%= dateVal %>" required>
                            </div>

                            <div class="mb-3">
                                <label for="start" class="form-label">Giờ bắt đầu</label>
                                <input type="time" class="form-control" id="start" name="start"
                                    value="<%= suatchieu.start %>" required>
                            </div>
                            <div class="mb-3">
                                <label for="end" class="form-label">Giờ kết thúc</label>
                                <input type="time" class="form-control" id="end" name="end"
                                    value="<%= suatchieu.end %>" required>
                            </div>
                            <button type="submit" class="btn btn-primary"><i class="bi bi-cloud-arrow-up"></i> Cập nhật
                                suất chiếu</button>
                    </form>
                </div>
            </div>

            <div id="footer">
                <%- include('footer') %>
            </div>

            <%- include('javascript') %>
    </div>
</body>

</html>
<% if (error) { %>
    <script>
        alert("<%= error %>");
    </script>
    <% } %>