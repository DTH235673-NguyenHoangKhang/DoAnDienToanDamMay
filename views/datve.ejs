<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/CSS/DoAn.css" />
    <title><%= title %> - Quản lý rạp phim</title>
</head>
<body>
    <div id="khungtrang">
        <div id="header">
            <img src="/images/banner.jpg" style="width: 100%;" />
        </div>

        <%- include('navbar') %>

        <div class="card-body">
            <div class="cinema-container text-center">
                <div class="screen mb-4" style="margin-top: 10px; background: #ddd; padding: 10px; border-radius: 5px;">MÀN HÌNH</div>

                <div class="seats-layout">
                    <% let listHang=['A', 'B' , 'C' , 'D' , 'E' ]; %>
                    <% listHang.forEach(function(hang) { %>
                        <div class="seat-row d-flex justify-content-center mb-2">
                            <span class="row-label me-3 fw-bold"><%= hang %></span>
                            <% for(let i=1; i<=10; i++) { 
                                let maGhe = hang + i; 
                                let daDat = gheDaBan.includes(maGhe) ? 'occupied' : ''; 
                            %>
                                <div class="seat border p-2 m-1 text-center <%= daDat %>" 
                                     data-seat="<%= maGhe %>" 
                                     style="width: 40px; height: 40px; border-radius: 5px;">
                                    <%= i %>
                                </div>
                            <% } %>
                        </div>
                    <% }); %>
                </div>
            </div>

            <div class="booking-summary mt-4 p-3 border-top text-center">
                <h5>Thông tin đặt vé</h5>
                <p>Ghế đã chọn: <span id="selected-seats-list" class="fw-bold text-danger">Chưa chọn</span></p>
                <p id="p-original" style="display: none;">Tổng tiền gốc: <span id="original-price" class="text-decoration-line-through text-muted">0</span> VNĐ</p>
                <p>Thành tiền: <span id="total-price" class="fw-bold text-primary fs-4">0</span> VNĐ</p>

                <div class="loyalty-box mb-3 p-3 border rounded bg-light text-start mx-auto" style="max-width: 500px;">
                    <label class="fw-bold"><i class="bi bi-coin text-warning"></i> Blockchain Loyalty</label>
                    <div class="d-flex justify-content-between align-items-center mt-2">
                        <span>Số dư: <strong id="user-balance"><%= taikhoan.DiemLoyalty || 0 %></strong> Token</span>
                        <div class="form-check form-switch">
                            <input class="form-check-input" type="checkbox" id="use-points" data-points="<%= taikhoan.DiemLoyalty || 0 %>">
                            <label class="form-check-label" for="use-points">Dùng điểm (1 Token = 1.000đ)</label>
                        </div>
                    </div>
                    <small id="loyalty-msg" class="text-success" style="display: none;"></small>
                </div>

                <form action="/xuly-datve" method="POST" id="formDatVe" style="max-width: 500px; margin: 0 auto;">
                    <input type="hidden" name="idSuatChieu" id="idSuatChieu" value="<%= suatChieu._id %>">
                    <input type="hidden" name="danhSachGhe" id="inputGhe">
                    <input type="hidden" name="tongTien" id="inputTien">
                    <input type="hidden" name="diemSuDung" id="inputDiemSuDung" value="0">

                    <button type="submit" id="btn-pay" class="btn btn-success btn-lg w-100" disabled>THANH TOÁN</button>
                </form>
            </div>
        </div>

    </div>

    <script src="/socket.io/socket.io.js"></script>
    <script>
        const socket = io();
        const suatChieuId = document.getElementById('idSuatChieu').value;
        const seats = document.querySelectorAll('.seat:not(.occupied)');
        const selectedSeatsList = document.getElementById('selected-seats-list');
        const totalPriceElement = document.getElementById('total-price');
        const originalPriceElement = document.getElementById('original-price');
        const pOriginal = document.getElementById('p-original');
        const btnPay = document.getElementById('btn-pay');
        const usePointsSwitch = document.getElementById('use-points');
        const loyaltyMsg = document.getElementById('loyalty-msg');
        const inputGhe = document.getElementById('inputGhe');
        const inputTien = document.getElementById('inputTien');
        const inputDiemSuDung = document.getElementById('inputDiemSuDung');

        let selectedSeats = [];
        const GIA_VE = 65000;
        const DIEM_QUY_DOI = 1000;

        // 1. KẾT NỐI REALTIME
        socket.emit('join-cinema-room', suatChieuId);

        socket.on('seat-is-being-held', (maGhe) => {
            const seat = document.querySelector(`[data-seat="${maGhe}"]`);
            if (seat) seat.classList.add('being-held');
        });

        socket.on('seat-is-released', (maGhe) => {
            const seat = document.querySelector(`[data-seat="${maGhe}"]`);
            if (seat) seat.classList.remove('being-held');
        });

// 2. LOGIC TÍNH TIỀN
        function updateUI() {
            let soLuong = selectedSeats.length;
            let tongTienGoc = soLuong * GIA_VE;
            let diemHienCo = parseInt(usePointsSwitch.getAttribute('data-points')) || 0;
            let thanhTien = tongTienGoc;
            let diemSeDung = 0;

            if (usePointsSwitch.checked && soLuong > 0) {
                // --- LOGIC MỚI: TÍNH GIỚI HẠN 50% ---
                // Số tiền tối đa có thể trừ là 50% tiền gốc
                let soTienGiamToiDa = Math.floor(tongTienGoc * 0.5);
                
                // Quy đổi số tiền giảm tối đa này ra điểm (ví dụ: giảm 32.500đ cần 32.5 điểm)
                let diemToiDaDuocDung = Math.floor(soTienGiamToiDa / DIEM_QUY_DOI);
                
                // Số điểm cần thiết để thanh toán toàn bộ (nhưng giờ sẽ bị chặn bởi diemToiDaDuocDung)
                let diemCanThiet = Math.ceil(tongTienGoc / DIEM_QUY_DOI);
                
                // diemSeDung = Giá trị nhỏ nhất trong 3 cái: (Điểm đang có, Điểm cần thiết, Điểm tối đa 50%)
                diemSeDung = Math.min(diemHienCo, diemCanThiet, diemToiDaDuocDung);
                
                thanhTien = tongTienGoc - (diemSeDung * DIEM_QUY_DOI);

                loyaltyMsg.innerHTML = `Dùng <b>${diemSeDung}</b> điểm. Giảm <b>${(diemSeDung * DIEM_QUY_DOI).toLocaleString()}đ</b> (Tối đa 50%).`;
                loyaltyMsg.style.display = 'block';
                pOriginal.style.display = 'block';
            } else {
                loyaltyMsg.style.display = 'none';
                pOriginal.style.display = 'none';
            }

            selectedSeatsList.innerText = soLuong > 0 ? selectedSeats.join(', ') : 'Chưa chọn';
            originalPriceElement.innerText = tongTienGoc.toLocaleString();
            totalPriceElement.innerText = thanhTien.toLocaleString();

            inputGhe.value = JSON.stringify(selectedSeats);
            inputTien.value = thanhTien;
            inputDiemSuDung.value = diemSeDung;
            btnPay.disabled = soLuong === 0;
        }
        // 3. SỰ KIỆN CLICK GHẾ
        seats.forEach(seat => {
            seat.addEventListener('click', () => {
                const maGhe = seat.getAttribute('data-seat');
                
                if (seat.classList.contains('being-held') || seat.classList.contains('occupied')) return;

                if (seat.classList.contains('selected')) {
                    seat.classList.remove('selected');
                    selectedSeats = selectedSeats.filter(s => s !== maGhe);
                    socket.emit('client-release-seat', { suatChieuId, maGhe });
                } else {
                    seat.classList.add('selected');
                    selectedSeats.push(maGhe);
                    socket.emit('client-hold-seat', { suatChieuId, maGhe });
                }
                updateUI();
            });
        });

        usePointsSwitch.addEventListener('change', updateUI);
    </script>
</body>
</html>