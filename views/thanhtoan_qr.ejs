<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="/CSS/DoAn.css" />
    <title>
        <%= title%> - Quản lý rạp phim
    </title>
</head>

<body>
<div class="container text-center">
    <h3>Quét mã QR để thanh toán</h3>
    <p>Thời gian còn lại: <span id="timer" style="color: red; font-weight: bold;">05:00</span></p>
    
    <img src="<%= qrUrl %>" alt="Mã QR Thanh Toán" style="max-width: 300px; border: 1px solid #ccc;">
    
    <div class="mt-4">
        <p>Nội dung chuyển khoản: <strong>Thanh toan ve <%= orderId %></strong></p>
        <p>Số tiền: <strong><%= tongTien %> VNĐ</strong></p>
    </div>

</div>
<script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>
<script>
    const orderId = "<%= orderId %>";
    let checkInterval;
    async function checkStatus() {
        try {
            const response = await axios.get(`/api/check-payment/${orderId}`);
            if (response.data.success === true) {
                // Nếu thành công, dừng kiểm tra và chuyển hướng
                clearInterval(checkInterval);
                
                // Chuyển hướng đến Route xử lý logic Blockchain/Loyalty bạn đã viết
                window.location.href = `/xac-nhan-chuyen-khoan/${orderId}`;
            }
        } catch (err) {
            console.error("Lỗi kiểm tra thanh toán:", err);
        }
    }

    // Bắt đầu kiểm tra sau khi trang load 5 giây, mỗi 3 giây check 1 lần
    setTimeout(() => {
        checkInterval = setInterval(checkStatus, 3000);
    }, 5000);
    // Logic đếm ngược 5 phút
    let time = 300; // 5 phút = 300 giây
    const timerElement = document.getElementById('timer');

    const countdown = setInterval(() => {
        let minutes = Math.floor(time / 60);
        let seconds = time % 60;
        seconds = seconds < 10 ? '0' + seconds : seconds;
        timerElement.innerHTML = `${minutes}:${seconds}`;
        time--;

        if (time < 0) {
            clearInterval(countdown);
            alert("Đã hết thời gian thanh toán!");
            window.location.href = "/"; // Quay lại trang chủ
        }
    }, 1000);

    // DỌN LỖI: Khai báo các hàm mà file custom.min.js của bạn đang đòi hỏi
    window.updateTime = function() {};
    window.timer = 0;
</script>
</body>
</html>