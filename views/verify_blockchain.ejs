<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        .status-header { padding: 20px; border-radius: 8px; margin-bottom: 20px; text-align: center; }
        .valid-bg { background-color: #d4edda; color: #155724; }
        .invalid-bg { background-color: #f8d7da; color: #721c24; }
    </style>
</head>
<body class="container mt-5">
    <h1 class="mb-4 text-center">🛡️ Kiểm soát Toàn bộ Hệ thống Loyalty</h1>

    <div class="status-header <%= (overallStatus.includes('An toàn')) ? 'valid-bg' : 'invalid-bg' %>">
        <h2><%= overallStatus %></h2>
    </div>

    <% if (!isBalanceMatch) { %>
        <div class="alert alert-danger text-center fw-bold">
            ⚠️ CẢNH BÁO: Có một hoặc nhiều tài khoản bị thay đổi số dư trái phép!
        </div>
    <% } %>

    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Người dùng</th>
                <th>Điểm (Database)</th>
                <th>Tổng điểm (Sổ cái)</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            <% report.forEach(user => { %>
                <tr class="<%= !user.isMatch || !user.isChainValid ? 'table-danger' : '' %>">
                    <td><%= user.username %></td>
                    <td class="fw-bold"><%= user.dbBalance %></td>
                    <td><%= user.ledgerBalance %></td>
                    <td class="fw-bold"><%= user.status %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <div class="mt-3">
        <a href="/" class="btn btn-primary">Quay lại trang chủ</a>
    </div>
</body></html>