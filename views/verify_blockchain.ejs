<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        .status-header { padding: 20px; border-radius: 8px; margin-bottom: 20px; text-align: center; }
        .valid-bg { background-color: #d4edda; color: #155724; border: 2px solid #c3e6cb; }
        .invalid-bg { background-color: #f8d7da; color: #721c24; border: 2px solid #f5c6cb; }
        .card-check { margin-bottom: 20px; }
        .alert-critical { border-left: 5px solid #dc3545; font-weight: bold; }
    </style>
</head>
<body class="container mt-5">
    <h1 class="mb-4 text-center">🛡️ Kiểm định Sổ cái Blockchain</h1>

    <div class="status-header <%= (isValidChain && isBalanceMatch) ? 'valid-bg' : 'invalid-bg' %>">
        <h2><%= overallStatus %></h2>
    </div>

    <% if (!isBalanceMatch) { %>
        <div class="alert alert-danger alert-critical shadow-sm mb-4" role="alert">
            ⚠️ <strong>CẢNH BÁO HỆ THỐNG:</strong> Phát hiện tài khoản có dấu hiệu bị can thiệp số dư trực tiếp từ Database!
        </div>
    <% } %>

    <div class="row card-check">
        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Tính toàn vẹn dữ liệu</h5>
                    <p class="display-6"><%= isValidChain ? '✅' : '❌' %></p>
                    <p class="text-muted small">Mã băm (Hash) giữa các bản ghi lịch sử.</p>
                </div>
            </div>
        </div>

        <div class="col-md-6">
            <div class="card h-100 shadow-sm">
                <div class="card-body text-center">
                    <h5 class="card-title">Đối soát số dư tài khoản</h5>
                    <p class="display-6"><%= isBalanceMatch ? '✅' : '❌' %></p>
                    <div class="d-flex justify-content-around mt-2">
                        <div>
                            <span class="badge bg-secondary">Điểm trong Database</span>
                            <h4 class="<%= !isBalanceMatch ? 'text-danger' : '' %>"><%= dbBalance %></h4>
                        </div>
                        <div>
                            <span class="badge bg-secondary">Tổng từ Sổ cái</span>
                            <h4><%= ledgerBalance %></h4>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <h4 class="mt-4">Chi tiết các Block trong Sổ cái</h4>
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Thứ tự</th>
                <th>ID Block</th>
                <th>Hành động</th>
                <th>Số điểm</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            <% report.forEach(item => { %>
                <tr class="<%= item.status.includes('can thiệp') ? 'table-danger' : '' %>">
                    <td><%= item.index + 1 %></td>
                    <td><small class="text-muted"><%= item.id %></small></td>
                    <td>
                        <span class="badge <%= item.action === 'REWARD' ? 'bg-success' : 'bg-warning text-dark' %>">
                            <%= item.action %>
                        </span>
                    </td>
                    <td><strong><%= item.action === 'REWARD' ? '+' : '-' %> <%= item.points %></strong></td>
                    <td class="fw-bold"><%= item.status %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <div class="mt-4 mb-5">
        <a href="/" class="btn btn-outline-secondary">Quay lại trang chủ</a>
    </div>
</body>
</html>