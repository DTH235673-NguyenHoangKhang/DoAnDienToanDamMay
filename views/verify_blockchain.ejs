<!DOCTYPE html>
<html>
<head>
    <title><%= title %></title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <style>
        .status-header { padding: 20px; border-radius: 8px; margin-bottom: 20px; text-align: center; }
        .valid-bg { background-color: #d4edda; color: #155724; }
        .invalid-bg { background-color: #f8d7da; color: #721c24; }
    </style>
</head>
<body class="container mt-5">
    <h1 class="mb-4 text-center">🛡️ Kiểm định Sổ cái Blockchain</h1>

    <div class="status-header <%= overallStatus.includes('An toàn') ? 'valid-bg' : 'invalid-bg' %>">
        <h2><%= overallStatus %></h2>
    </div>

    <table class="table table-bordered table-striped">
        <thead class="table-dark">
            <tr>
                <th>Thứ tự (Block)</th>
                <th>Mã giao dịch (ID)</th>
                <th>Hành động</th>
                <th>Trạng thái</th>
            </tr>
        </thead>
        <tbody>
            <% report.forEach(item => { %>
                <tr>
                    <td><%= item.index %></td>
                    <td><small><%= item.id %></small></td>
                    <td><%= item.action %></td>
                    <td class="fw-bold"><%= item.status %></td>
                </tr>
            <% }) %>
        </tbody>
    </table>

    <div class="mt-3">
        <a href="/" class="btn btn-primary">Quay lại trang chủ</a>
    </div>
</body>
</html>